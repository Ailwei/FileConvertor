{
    "version": 2,
    "builds": [
      {
        "src": "vite.config.js",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "dist"
        }
      }
    ],
    "rewrites": [
      {
        "source": "/auth/(.*)",
        "destination": "https://file-convertor-nu.vercel.app/auth/$1"
      },
      {
        "source": "/(.*)",
        "destination": "/"
      }
    ]
  }
  
  