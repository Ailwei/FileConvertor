{
    "version": 2,
    "builds": [
      {
        "src": "src/index.js",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "build"
        }
      }
    ],
    "rewrites": [
      { "source": "/auth/(.*)", "destination": "file-convertor-nu.vercel.app/auth/$1" },
      { "source": "/(.*)", "destination": "/" }
    ]
  }
  